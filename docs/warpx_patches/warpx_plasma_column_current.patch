+
+void BackgroundMCCCollision::doBackgroundIonImpactIonization (
+    int lev,
+    amrex::LayoutData<amrex::Real>* cost,
+    WarpXParticleContainer& projectile_species,
+    WarpXParticleContainer& electron_species,
+    WarpXParticleContainer& ion_species,
+    amrex::Real t)
+{
+    ABLASTR_PROFILE("BackgroundMCCCollision::doBackgroundIonImpactIonization()");
+
+    const SmartCopyFactory copy_factory_electron(projectile_species, electron_species);
+    const SmartCopyFactory copy_factory_ion(projectile_species, ion_species);
+
+    const auto CopyElectron = copy_factory_electron.getSmartCopy();
+    const auto CopyIon = copy_factory_ion.getSmartCopy();
+
+    const auto Filter = IonImpactIonizationFilterFunc(
+        m_ion_impact_ionization_processes[0],
+        m_mass1,
+        m_background_mass,
+        m_total_collision_prob_ion_impact_ioniz,
+        m_nu_max_ion_impact_ioniz,
+        m_background_density_func,
+        t);
+
+    const amrex::ParticleReal sqrt_kb_m_gas =
+        std::sqrt(PhysConst::kb / m_background_mass);
+
+#ifdef AMREX_USE_OMP
+#pragma omp parallel if (amrex::Gpu::notInLaunchRegion())
+#endif
+    for (WarpXParIter pti(projectile_species, lev); pti.isValid(); ++pti)
+    {
+        if (cost && WarpX::load_balance_costs_update_algo == LoadBalanceCostsUpdateAlgo::Timers) {
+            amrex::Gpu::synchronize();
+        }
+
+        auto wt = static_cast<amrex::Real>(amrex::second());
+
+        auto& projectile_tile = projectile_species.ParticlesAt(lev, pti);
+        auto& electron_tile = electron_species.ParticlesAt(lev, pti);
+        auto& ion_tile = ion_species.ParticlesAt(lev, pti);
+
+        const auto np_electron = electron_tile.numParticles();
+        const auto np_ion = ion_tile.numParticles();
+
+        auto Transform = IonImpactIonizationTransformFunc(
+            m_ion_impact_ionization_processes[0].getEnergyPenalty(),
+            m_mass1,
+            m_ion_impact_secondary_electron_energy,
+            sqrt_kb_m_gas,
+            m_background_temperature_func,
+            t);
+
+        const auto num_added = filterCopyTransformParticles<1>(
+            electron_species,
+            ion_species,
+            electron_tile,
+            ion_tile,
+            projectile_tile,
+            np_electron,
+            np_ion,
+            Filter,
+            CopyElectron,
+            CopyIon,
+            Transform);
+
+        setNewParticleIDs(electron_tile, np_electron, num_added);
+        setNewParticleIDs(ion_tile, np_ion, num_added);
+
+        if (cost && WarpX::load_balance_costs_update_algo == LoadBalanceCostsUpdateAlgo::Timers) {
+            amrex::Gpu::synchronize();
+            wt = static_cast<amrex::Real>(amrex::second()) - wt;
+            amrex::HostDevice::Atomic::Add(&(*cost)[pti.index()], wt);
+        }
+    }
+}
